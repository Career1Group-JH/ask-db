{
  "name": "askdb-frontend",
  "private": true,
  "version": "0.7.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm run sync-version",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync-version": "node --input-type=commonjs -e \"const fs=require('fs');const paths=['../VERSION','./VERSION'];for(const p of paths){try{const v=fs.readFileSync(p,'utf8').trim();const pkg=JSON.parse(fs.readFileSync('package.json','utf8'));if(pkg.version!==v){pkg.version=v;fs.writeFileSync('package.json',JSON.stringify(pkg,null,2)+'\\n');console.log('Version synced to '+v)}break}catch{}}\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
